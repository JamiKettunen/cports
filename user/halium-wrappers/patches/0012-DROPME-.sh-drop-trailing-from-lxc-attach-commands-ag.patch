From ad8a580137d35124ab2e250239467fc984c7f06d Mon Sep 17 00:00:00 2001
From: Jami Kettunen <jami.kettunen@protonmail.com>
Date: Tue, 17 Sep 2024 20:04:46 +0300
Subject: [PATCH 12/14] [DROPME?] *.sh: drop trailing \; from lxc-attach
 commands again

root@chimera:~# android_start vendor.hwcomposer-2-3
Unable to start service ';'
See dmesg for error reason.
---
 src/android-service.sh | 2 +-
 src/halium-lxc-exec.sh | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/android-service.sh b/src/android-service.sh
index 00abd6f..13048d9 100644
--- a/src/android-service.sh
+++ b/src/android-service.sh
@@ -52,7 +52,7 @@ stop() {
 	if [ -z "${ANDROID_SERVICE_FORCE_KILL}" ]; then
 		WAITFORSERVICE_VALUE="stopped" timeout 5 waitforservice init.svc.${service_service}
 	else
-		pid=$(lxc-attach -n ${LXC_CONTAINER_NAME} -- /bin/pidof ${service_process} \;)
+		pid=$(lxc-attach -n ${LXC_CONTAINER_NAME} -- /bin/pidof ${service_process})
 		[ -n "${pid}" ] && android_kill -9 ${pid}
 		setprop init.svc.${service_service} stopped
 	fi
diff --git a/src/halium-lxc-exec.sh b/src/halium-lxc-exec.sh
index 8385c3a..ae2a86d 100755
--- a/src/halium-lxc-exec.sh
+++ b/src/halium-lxc-exec.sh
@@ -24,4 +24,4 @@ found_path=$(whereis -b -B ${ANDROID_SEARCH_PATH} -f ${TARGET_BINARY} | awk '{ p
 unset LD_PRELOAD
 
 # Finally execute
-exec lxc-attach -n ${LXC_CONTAINER_NAME} -- ${found_path#${LXC_CONTAINER_PATH}} "${@}" \;
+exec lxc-attach -n ${LXC_CONTAINER_NAME} -- ${found_path#${LXC_CONTAINER_PATH}} "${@}"
-- 
